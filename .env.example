# Trip Planner Mobile — environment variables
# Copy this file to `.env.local` and fill in real values.

# Base URL of the existing Trip Planner web application API.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Map provider key (used by the route/map screens).
NEXT_PUBLIC_MAP_API_KEY=

# Feature flag: set to "true" to use mock data instead of the live API.
NEXT_PUBLIC_USE_MOCKS=true
